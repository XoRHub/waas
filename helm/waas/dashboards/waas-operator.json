{
  "title": "WaaS / Operator",
  "uid": "waas-operator",
  "tags": ["waas"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Workspaces by phase",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (phase) (waas_operator_workspaces)",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Drifted workspaces",
      "description": "TemplateDrifted condition True: the desired configuration changed, applies at next resume or manual reload (docs/adr/0001).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "waas_operator_workspaces_drifted" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Teardown failures (24h)",
      "description": "Failed finalizer passes — workspaces stuck Terminating (see docs/workspace-deletion.md).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "sum(increase(waas_operator_teardown_failures_total[24h]))" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Namespace reclaims (janitor)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(waas_operator_namespace_reclaims_total[1h]))",
          "legendFormat": "reclaims / h"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reconcile rate by controller",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_total[5m]))",
          "legendFormat": "{{controller}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Reconcile errors by controller",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "min": 0, "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_errors_total[5m]))",
          "legendFormat": "{{controller}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Workqueue depth",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (workqueue_depth)",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ]
}
