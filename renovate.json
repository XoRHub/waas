{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Monorepo config: Dockerfiles, CI job images across .github/workflows/, tool pins in scripts and Makefiles. The waas-images repo (split out 2026-07-10) carries its own config again.",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    "mergeConfidence:all-badges"
  ],
  "packageRules": [
    {
      "description": "One PR for all GitHub Actions patch/minor/digest bumps, automerged once required checks pass.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor", "digest", "pinDigest"],
      "groupName": "github-actions",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Go/TS patch and minor bumps automerge once required checks pass, the release is >=10 days old, and Renovate's merge confidence is neutral or better.",
      "matchManagers": ["gomod", "npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "minimumReleaseAge": "10 days",
      "automerge": true,
      "platformAutomerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Container tools run via `docker run` in GitHub workflows (gitleaks, kubeconform, hadolint).",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?<depName>[a-z0-9.\\/-]+\\/(?:gitleaks|kubeconform|hadolint)):(?<currentValue>v?[a-zA-Z0-9.-]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Official kasmweb images referenced by the workspace catalog and templates (tag@digest bumped together — the catalog matches templates verbatim).",
      "managerFilePatterns": [
        "/^gitops/governance/images\\.ya?ml$/",
        "/^hack/dev/(images|templates)-dev\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?<depName>docker\\.io/kasmweb/[a-z0-9-]+):(?<currentValue>[0-9][a-zA-Z0-9.-]*)(?:@(?<currentDigest>sha256:[a-f0-9]{64}))?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "controller-gen pin in operator/Makefile.",
      "managerFilePatterns": [
        "/^operator/Makefile$/"
      ],
      "matchStrings": [
        "CONTROLLER_GEN_VERSION \\?= (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "setup-envtest pin in operator/Makefile (ENVTEST_K8S_VERSION is deliberate: it tracks the k8s.io/* minor in go.mod, not the latest).",
      "managerFilePatterns": [
        "/^operator/Makefile$/"
      ],
      "matchStrings": [
        "SETUP_ENVTEST_VERSION \\?= (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "sigs.k8s.io/controller-runtime/tools/setup-envtest",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "tygo pin in the root Makefile (generated TS types).",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "go run (?<depName>github\\.com/gzuidhof/tygo)@(?<currentValue>v[0-9.]+)"
      ],
      "datasourceTemplate": "go"
    }
  ]
}